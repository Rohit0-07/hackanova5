# ─── Research Paper Graph — Backend Environment Variables ─────────────────────
# Copy this file to .env and fill in your values.
# NEVER commit the actual .env file to version control.

# ─── LLM Provider ─────────────────────────────────────────────────────────────
LLM_PROVIDER=ollama                         # "ollama" or "gemini"
GEMINI_API_KEY=                             # Your Google Gemini API key

# ─── Ollama (local LLM, optional) ─────────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=gemma3:latest
OLLAMA_VISION_MODEL=llava:latest

# ─── Email Notifications (Resend API — recommended) ───────────────────────────
# Paste your Resend API key here:
RESEND_API_KEY=                         # Paste your Resend API key here
RESEND_FROM_EMAIL=onboarding@resend.dev  # Use verified domain in production

# Option B: Generic SMTP credentials (Gmail, Outlook, etc.)
# Leave blank if using Mailtrap API token instead
EMAIL_SMTP_HOST=
EMAIL_SMTP_PORT=587
EMAIL_SENDER=
EMAIL_PASSWORD=

# Frontend URL embedded in notification emails (backlink)
APP_BASE_URL=http://localhost:3000

# ─── Neo4j Database (optional — future phase) ─────────────────────────────────
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=password

# ─── API Server ───────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
