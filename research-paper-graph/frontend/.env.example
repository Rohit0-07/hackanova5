# ─── Research Paper Graph — Frontend Environment Variables ────────────────────
# Copy to .env (for local dev) or .env.production (for prod builds).
# Variables MUST start with REACT_APP_ to be accessible in the browser.

# Backend API base URL (must include /api/v1 — this is what axios uses as baseURL)
REACT_APP_API_URL=http://localhost:8000/api/v1
